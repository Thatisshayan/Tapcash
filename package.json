{
  "name": "tapcash",
  "version": "1.0.0",
  "private": true,
  "main": "src-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "monitoring:deploy": "betteruptime push --config better-uptime.yml",
    "monitoring:validate": "betteruptime validate --config better-uptime.yml",
    "sentry:upload-sourcemaps": "sentry-cli sourcemaps inject --org $SENTRY_ORG --project $SENTRY_PROJECT .next && sentry-cli sourcemaps upload --org $SENTRY_ORG --project $SENTRY_PROJECT .next",
    "health:check": "curl -f http://localhost:3000/api/health",
    "desktop": "electron ."
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@sentry/nextjs": "^10.56.0",
    "@tailwindcss/postcss": "^4",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-confetti": "^6.4.0",
    "react-dom": "19.2.4",
    "react-use": "^17.6.1",
    "resend": "^6.12.3",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.29.0",
    "eslint-config-next": "^16.2.6",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "caniuse-lite": {
    "data": {}
