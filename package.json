{
  "name": "tapcash",
  "version": "1.0.0",
  "private": true,
  "main": "src-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
