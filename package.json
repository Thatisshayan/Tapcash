    "@vercel/speed-insights": "^2.0.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "msw-trpc": "^2.0.1",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "react": "19.2.7",
    "react-confetti": "^6.4.0",
