    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "monitoring:deploy": "betteruptime push --config better-uptime.yml",
    "monitoring:validate": "betteruptime validate --config better-uptime.yml",
    "sentry:upload-sourcemaps": "sentry-cli sourcemaps inject --org $SENTRY_ORG --project $SENTRY_PROJECT .next && sentry-cli sourcemaps upload --org $SENTRY_ORG --project $SENTRY_PROJECT .next",
    "health:check": "curl -f http://localhost:3000/api/health",
    "desktop": "electron ."
  },
  "dependencies": {
