rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      // Only allow update if they aren't touching secure fields
      allow update: if isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                      ['admin', 'walletBalanceCents', 'wallet', 'ledgerBalanceCoins', 'totalEarned', 'status', 'isFlagged', 'flaggedReason']
                    );
      allow create: if isOwner(userId);
      allow delete: if false;
    }

    // Ledger-first collections
    match /ledger_transactions/{ledgerId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /offer_clicks/{clickId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /offer_postbacks/{postbackId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /cashout_requests/{requestId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /fraud_flags/{flagId} {
      allow read, write: if false;
    }

    match /admin_actions/{actionId} {
      allow read, write: if false;
    }

    // Legacy / transitional collections
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Only written by Admin SDK
    }

    // Root-level withdrawals
    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Only written by Admin SDK
    }
    
    // Offers are globally readable but not writable by clients
    match /offers/{offerId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Tasks can only be read by the owner, written only by Admin SDK
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    
    // Audit events can be created by users (append-only) for tracking
    match /events/{eventId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Admin namespace placeholder
    match /admin/{document=**} {
      allow read, write: if false;
    }
    match /adminLogs/{document=**} {
      allow read, write: if false;
    }
    match /admin_logs/{document=**} {
      allow read, write: if false;
    }
    match /blocked_ips/{document=**} {
      allow read, write: if false;
    }
  }
}
