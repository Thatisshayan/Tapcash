rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write their own profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Wallet and transactions are read-only for users, written only by Cloud Functions
      match /wallet/{document=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; 
      }
    }
    
    // Offers are globally readable but not writable by clients
    match /offers/{offerId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Tasks can only be read by the owner, written only by Cloud Functions
    match /tasks/{taskId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
    
    // Audit events can be created by users (append-only) for tracking
    match /events/{eventId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }
    
    // Admin namespace placeholder (protected by custom claims in the future)
    match /admin/{document=**} {
      allow read, write: if false;
    }
  }
}
