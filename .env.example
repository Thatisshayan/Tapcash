# Environment variables for TapCash
# Copy to .env.local and fill in values. Real values are gitignored.

# Firebase Configuration (Client-side - safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server-side only) — rotated June 7, 2026
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# App Configuration
NEXT_PUBLIC_APP_URL=https://tapcash.com
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://tapcash.com

# Offerwall (Lootably - first integration)
ALLOWED_POSTBACK_IPS=54.210.231.13,18.216.131.137
LOOTABLY_API_KEY=
LOOTABLY_SECRET_KEY=

# Offerwall (RapidoReach)
NEXT_PUBLIC_RAPIDOREACH_APP_ID=
RAPIDOREACH_APP_ID=
RAPIDOREACH_APP_KEY=
RAPIDOREACH_APP_SECRET=
RAPIDOREACH_TRANSACTION_KEY=
RAPIDOREACH_CALLBACK_URL=https://tapcash.online/api/postback/rapidoreach

# Payout Gateways

# PayPal Configuration
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Interac e-Transfer Configuration
INTERAC_API_KEY=
INTERAC_API_SECRET=
INTERAC_ENVIRONMENT=sandbox

# Tremendous Gift Cards Configuration
TREMENDOUS_API_KEY=
TREMENDOUS_CAMPAIGN_ID=
TREMENDOUS_ENVIRONMENT=sandbox

# Security & Monitoring
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_LIMIT=100

# Cron Security
CRON_SECRET=

# Better Uptime Monitoring
BETTER_UPTIME_API_KEY=

# Email (for password reset, verification)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=